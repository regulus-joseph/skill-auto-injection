{
  "name": "skill-auto-injection",
  "version": "0.3.0",
  "type": "module",
  "description": "Auto-match user delivery task with available skills for better agent responses",
  "main": "src/index.ts",
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.5",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "changelog": [
    {
      "version": "0.3.0",
      "date": "2026-04-25",
      "changes": [
        "L1 keyword match: zero-cost keyword trigger before embedding",
        "LLM keyword extraction on skill load (3-5 trigger keywords per skill)",
        "Skip translation when query already contains English characters",
        "L1+L2 cascade: keyword match first, embed fallback"
      ]
    },
    {
      "version": "0.2.0",
      "date": "2026-04-22",
      "changes": [
        "添加多provider翻译支持(ollama/minimax/openai)",
        "优化日志输出,便于调试",
        "修复bug: 重复的匹配逻辑代码"
      ]
    },
    {
      "version": "0.1.0",
      "date": "2026-04-22",
      "changes": [
        "初始版本",
        "基于embedding的skill匹配",
        "before_agent_start hook自动注入",
        "支持翻译功能处理跨语言匹配"
      ]
    }
  ]
}
